# PostgreSQL connection - either full URL or components
DATABASE_URL=postgresql://user:password@localhost:5432/careerdb

# JWT secret
JWT_SECRET=change_this_secret

# Frontend base URL used in emails
FRONTEND_URL=http://localhost:3000

# (Optional) SMTP settings for nodemailer. If omitted tokens are logged to console.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
